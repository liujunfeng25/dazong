{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:tianshu && vite build",
    "build:app": "vite build",
    "build:tianshu": "npm --prefix tianshu-src install --no-audit --no-fund && npm --prefix tianshu-src run build",
    "preview": "vite preview",
    "test:unit": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:order": "playwright test e2e/client-order-flow.spec.ts",
    "test:e2e:fence": "playwright test e2e/electronic-fence-draw.spec.ts",
    "test:e2e:beijing": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-$PWD/node_modules/.cache/ms-playwright} playwright test e2e/beijing-amap-cockpit.spec.ts",
    "test:e2e:ai-chat": "playwright test e2e/monitor-ai-chat.spec.ts"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@unocss/reset": "^66.6.8",
    "axios": "^1.15.2",
    "dompurify": "^3.4.5",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.7",
    "hls.js": "^1.6.16",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "unocss": "^66.6.8",
    "vite": "^8.0.10"
  }
}
