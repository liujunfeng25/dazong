VITE_API_PROXY_TARGET=http://127.0.0.1:18000
VITE_AMAP_KEY=your_amap_key
# Docker：`dazong/docker-compose.yml` 的 frontend 服务已 `env_file: ./frontend/.env`，此处填好 Key 后
# `docker compose up` 即可带到容器（仅 `VITE_API_PROXY_TARGET` 会被 compose 覆盖为 backend:8000）。
# JS API 2.0 安全密钥（控制台「应用 Key」同页或安全设置中）；商业基础版 Key 通常需配置后在线瓦片才稳定
# VITE_AMAP_SECURITY_JS_CODE=your_security_js_code
# 自定义地图样式：在控制台关闭「地铁/轨道交通」等图层后，填样式 ID 或完整 amap://styles/xxx（隐藏地铁线最可靠）
# VITE_AMAP_MAP_STYLE_ID=your_style_uuid
# 或 VITE_AMAP_MAP_STYLE=amap://styles/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_WS_BASE_URL=ws://127.0.0.1:18000
VITE_DEMO_MODE=true
