# Docker Compose 共用变量（复制为 .env：cp .env.example .env）
# 默认启用开发栈：COMPOSE_PROFILES=dev

COMPOSE_PROFILES=dev

MYSQL_ROOT_PASSWORD=116165
MYSQL_DATABASE=dazong
MYSQL_USER=root
MYSQL_PASSWORD=116165

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

JWT_SECRET_KEY=dazong_demo_secret_2026
DEMO_MODE=true
SEED_ON_START=true
AUTO_CREATE_SCHEMA=true

# 容器内热重载会拖死后台任务；开发环境默认关闭 IoT 模拟器，需要时再改为 true
SIMULATOR_ENABLED=false

# 浏览器访问 MinIO 直链（宿主机端口）
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000/dazong-quality
