MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=116165
MYSQL_DB=dazong

JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173

DELIVERY_FEE_RATE=0.08

# AI 核心对话。真实密钥写 backend/.env，不写入代码或文档。
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL_PLANNER=qwen3.7-plus
AI_MODEL_ANSWER=qwen3.7-plus

# 新发地行情/预测
XINFADI_PRICE_API=http://www.xinfadi.com.cn/getPriceData.html
XINFADI_PRICE_TABLE=xinfadi_price_crawl
# 分页抓取时页与页之间额外随机 sleep（减轻同日内突发请求）
XINFADI_POLITE_CRAWL=false
# 批量补抓：每完成一天再抓下一天前的随机间隔（秒），新发地易在连续日后返回 503，可调大
XINFADI_BACKFILL_DAY_PAUSE_MIN=2.5
XINFADI_BACKFILL_DAY_PAUSE_MAX=6.0
# 慢速补抓（如"从 2024-01-01 慢补至今"）日级别间隔：默认 12~25 秒，避免长时间连续请求触发反爬识别
XINFADI_BACKFILL_SLOW_DAY_PAUSE_MIN=12.0
XINFADI_BACKFILL_SLOW_DAY_PAUSE_MAX=25.0
# 单页 POST 502/503/504/403/429 等错误的退避次数与基数（秒）
XINFADI_HTTP_MAX_RETRIES=5
XINFADI_HTTP_RETRY_BASE_SECONDS=1.5
XINFADI_MODELS_DIR=data/models/price_forecast

# 农产品价格网 zgncpjgw.com（采集入库，账号勿提交仓库）
ZGNCPJGW_BASE_URL=https://www.zgncpjgw.com
ZGNCPJGW_USERNAME=
ZGNCPJGW_PASSWORD=
ZGNCPJGW_PRICE_TABLE=zgncpjgw_price_crawl
ZGNCPJGW_POLITE_CRAWL=true
ZGNCPJGW_HTTP_MAX_RETRIES=5
ZGNCPJGW_HTTP_RETRY_BASE_SECONDS=1.2
ZGNCPJGW_PAGE_PAUSE_MIN=0.3
ZGNCPJGW_PAGE_PAUSE_MAX=1.0
ZGNCPJGW_CATEGORY_PAUSE_MIN=0.5
ZGNCPJGW_CATEGORY_PAUSE_MAX=2.0
ZGNCPJGW_DAY_PAUSE_MIN=0.3
ZGNCPJGW_DAY_PAUSE_MAX=1.0
ZGNCPJGW_EXPECTED_DISTRICTS=12
ZGNCPJGW_EXPECTED_CATEGORIES=12
ZGNCPJGW_CRAWL_CONCURRENCY=8

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dazong-quality
MINIO_SECURE=false
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000/dazong-quality
# 为 true 时后端会给桶设置匿名可读，直链预览才不是 AccessDenied；生产若只用预签名 URL 可改为 false
MINIO_ANONYMOUS_READ=true

DEMO_MODE=true
AUTO_CREATE_SCHEMA=true
SEED_ON_START=true
SIMULATOR_ENABLED=true
SIMULATOR_GPS_INTERVAL_SECONDS=5
SIMULATOR_SENSOR_INTERVAL_SECONDS=30
SIMULATOR_SENSOR_ALERT_CYCLE_SECONDS=300
WS_MONITOR_KPI_INTERVAL_SECONDS=3
WS_MONITOR_VEHICLE_INTERVAL_SECONDS=5
WS_RECONNECT_SECONDS=3

# 百度表格 OCR（与 ai-agent 相同变量名；不配则走演示数据）
# OCR_ENGINE=auto
# DOCUMENTS_BAIDU_TABLE_API_KEY=Bearer bce-v3/ALTAK-...
# 亦可使用：BAIDU_TABLE_API_KEY

# 北斗与萤石（配送商智能物流）
GPS18_BASE_URL=http://openapi.18gps.net
GPS18_USERNAME=
GPS18_PASSWORD=
# 以下为可选：历史轨迹 / 坐标系（不配则使用 config 默认值）
# GPS18_MAP_TYPE=
# GPS18_COORD_FOR_AMAP=auto
# GPS18_HISTORY_MAP_TYPE=
# GPS18_HISTORY_PLAY_LBS=0
# GPS18_HISTORY_METHOD=
# GPS18_HISTORY_METHOD_USER=
# GPS18_HISTORY_MAPTYPE_FALLBACK=1
# BEIDOU_HISTORY_MAX_SPAN_SECONDS=864000
# BEIDOU_HISTORY_MAX_POINTS=5000
# BEIDOU_HISTORY_MERGE_METERS=0
YS7_BASE_URL=https://open.ys7.com/api/lapp
YS7_APP_KEY=
YS7_APP_SECRET=
# 精创冷云标准 API V2（仓库温湿度仪，控制台：https://www.i-elitech.net）
ELITECH_BASE_URL=https://www.i-elitech.net
ELITECH_CLIENT_ID=
ELITECH_KEY_SECRET=
# 开放平台 API 用户名（如「北京中农食迅」），非网页登录手机号
ELITECH_USERNAME=
ELITECH_PASSWORD=
# 已开通 API 的设备 GUID，逗号分隔（getOpenDeviceList 不可用时 fallback）
ELITECH_DEVICE_GUIDS=
YS7_LIVE_URL_EXPIRE=300
YS7_LIVE_ADDRESS_INCLUDE_EXPIRE=0
YS7_LIVE_OPEN_BEFORE_GET=1
YS7_LIVE_PROTOCOL=2
YS7_LIVE_USE_EZOPEN=1

# 智能秤 UniApp 自更新（GET /api/system/smart-scale-app/version）
# 内网示例：SMART_SCALE_APP_APK_URL=http://192.168.1.10:9000/static/smart-scale.apk
# ngrok 示例（本仓库 apk-share + 端口 18080）：
#   bash scripts/publish-smart-scale-apk.sh smart-scale-uniapp/dist/release/apk/__UNI__....apk
#   会生成 smart-scale-YYYYMMDDHHmmss.apk，并把 smart-scale-latest.apk 软链到它（固定 URL 不变）
#   终端1: bash scripts/serve-apk-share.sh          # 等价于在 apk-share 下 python3 -m http.server 18080
#   终端2: ngrok http 18080
# SMART_SCALE_APP_APK_URL=https://你的子域.ngrok-free.dev/smart-scale-latest.apk
# 发版：manifest versionCode 递增 → 云打包 → 执行 publish 脚本 → 此处 VERSION_CODE 同步递增 → 重启后端
SMART_SCALE_APP_VERSION_CODE=100
SMART_SCALE_APP_VERSION_NAME=1.0.0
SMART_SCALE_APP_APK_URL=
SMART_SCALE_APP_WGT_URL=
SMART_SCALE_APP_FORCE_UPDATE=false
SMART_SCALE_APP_NOTES=

